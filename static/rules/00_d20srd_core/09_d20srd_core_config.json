  {
    "tableId": "config_multiclass_xp_penalty",
    "ruleSource": "srd_core",
    "data": {
      "rule": {
        "label": { "en": "Multiclass XP Penalty", "fr": "Pénalité d'XP multiclasse" },
        "description": {
          "en": "A character with two or more classes whose levels are not within 1 level of each other suffers a -20% XP penalty. Classes that are within 1 level of the highest-level class are not penalized. The character's favored class (listed per race) does not count when determining the penalty. If a character has no favored class, or all relevant classes are within 1 level of each other, there is no penalty.",
