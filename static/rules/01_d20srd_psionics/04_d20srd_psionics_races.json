    {
      "id": "race_maenad",
      "category": "race",
      "ruleSource": "srd_psionics",
      "label": {
        "en": "Maenad",
        "fr": "Ménade"
      },
      "description": {
        "en": "Maenads are a race of Medium humanoids with no ability score modifiers. They are characterized by intense waves of emotion alternating with periods of detached calm, and have a natural affinity for psionics. Maenads have a psi-like ability to release a burst of sonic energy, and can subject their mentality to gain brief bursts of physical strength.",
        "fr": "Les ménades sont une race d'humanoïdes de taille Moyenne sans modificateurs de caractéristiques. Elles se caractérisent par des vagues d'émotions intenses alternant avec des périodes de calme détaché, et ont une affinité naturelle pour la psionique."
      },
