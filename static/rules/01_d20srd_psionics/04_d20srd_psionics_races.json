    {
      "id": "race_duergar",
      "category": "race",
      "ruleSource": "srd_psionics",
      "label": {
        "en": "Duergar (Gray Dwarf)",
        "fr": "Duergar (Nain gris)"
      },
      "description": {
        "en": "Duergar are medium-sized humanoids related to dwarves but dwelling deep underground. They are harsh and unpleasant beings with a psionic heritage. They are resistant to magic, immune to paralysis and poison, and can become invisible or expand in size at will.",
        "fr": "Les duergars sont des humanoïdes de taille Moyenne apparentés aux nains mais habitant au plus profond des souterrains. Ils résistent à la magie, sont immunisés contre la paralysie et le poison, et peuvent devenir invisibles ou s'agrandir à volonté."
      },
