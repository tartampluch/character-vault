  {
    "tableId": "config_point_buy_costs",
    "ruleSource": "srd_core",
    "description": "D&D 3.5 point buy cost table. Each entry maps an ability score to the cumulative point cost from base 8. Scores below 8 grant points back. Used by PointBuyModal.svelte. Non-linear curve: scores 15+ cost significantly more to discourage extreme min-maxing.",
    "constraints": {
      "minimumScore": 7,
      "maximumScore": 18,
      "defaultScore": 8,
      "description": "No ability score below 7 or above 18 during point buy. Default starting score is 8 (cost 0). Common budgets: Low Fantasy=15, Standard=25, High Fantasy=32, Epic=45."
