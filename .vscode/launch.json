{
	"version": "0.2.0",
	"configurations": [
		// ─────────────────────────────────────────────────────────────────────
		// FRONTEND — SvelteKit (Vite dev server on port 5173)
		//
		// Prerequisites:
		//   1. Run `npm run dev` in a terminal (starts Vite on port 5173)
		//   2. Launch this configuration to attach Chrome DevTools to the
		//      running Vite server with full source-map support.
		//
		// Required VS Code extension: ms-edgetools.vscode-edge-devtools
		//   OR just use "Chrome" (msjsdiag.debugger-for-chrome / built-in)
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🟠 Frontend — Chrome (SvelteKit / Vite)",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				// Map Vite virtual module paths back to workspace sources
				"/@fs/*": "${workspaceFolder}/*",
				"/*": "${webRoot}/*"
			},
			"smartStep": true,
			"skipFiles": [
				"<node_internals>/**",
				"**/node_modules/**",
				"**/.svelte-kit/**"
			],
			"presentation": {
				"group": "1-frontend",
				"order": 1
			}
		},
		// Same as above but opens Microsoft Edge instead of Chrome
		{
			"name": "🟠 Frontend — Edge (SvelteKit / Vite)",
			"type": "msedge",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				"/@fs/*": "${workspaceFolder}/*",
				"/*": "${webRoot}/*"
			},
			"smartStep": true,
			"skipFiles": [
				"<node_internals>/**",
				"**/node_modules/**",
				"**/.svelte-kit/**"
			],
			"presentation": {
				"group": "1-frontend",
				"order": 2
			}
		},

		// ─────────────────────────────────────────────────────────────────────
		// BACKEND — PHP (Xdebug on port 9003)
		//
		// Prerequisites:
		//   1. Install Xdebug for PHP:
		//        pecl install xdebug
		//   2. Add to php.ini (or xdebug.ini):
		//        zend_extension=xdebug
		//        xdebug.mode=debug
		//        xdebug.start_with_request=yes
		//        xdebug.client_host=127.0.0.1
		//        xdebug.client_port=9003
		//   3. Start the PHP dev server:
		//        php -S localhost:8080 -t api api/index.php
		//      OR use the compound launch below to start everything at once.
		//   4. Launch this configuration — VS Code will listen for Xdebug
		//      connections on port 9003.
		//
		// Required VS Code extension: xdebug.php-debug
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🐘 Backend — PHP (Xdebug)",
			"type": "php",
			"request": "launch",
			// Listen for an incoming Xdebug connection (rather than spawning PHP)
			"port": 9003,
			"pathMappings": {
				// Map the server-side path to the local workspace path.
				// If running PHP locally (not in Docker) both sides are the same.
				"${workspaceFolder}/api": "${workspaceFolder}/api"
			},
			"log": false,
			"xdebugSettings": {
				"max_data": 65535,
				"show_hidden": 1,
				"max_children": 128,
				"max_depth": 5
			},
			"skipFiles": [
				"${workspaceFolder}/vendor/**"
			],
			"presentation": {
				"group": "2-backend",
				"order": 1
			}
		},

		// ─────────────────────────────────────────────────────────────────────
		// BACKEND — PHP (run built-in server + Xdebug in one shot)
		//
		// Spawns `php -S localhost:8080 -t api api/index.php` directly from
		// VS Code and simultaneously listens for the Xdebug connection.
		// Xdebug env vars are injected so no permanent php.ini change is needed.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🐘 Backend — PHP (spawn server + Xdebug)",
			"type": "php",
			"request": "launch",
			"runtimeArgs": [
				"-S", "localhost:8080",
				"-t", "${workspaceFolder}/api",
				"${workspaceFolder}/api/index.php"
			],
			"port": 9003,
			"env": {
				"XDEBUG_MODE": "debug",
				"XDEBUG_CONFIG": "client_host=127.0.0.1 client_port=9003 start_with_request=yes"
			},
			"pathMappings": {
				"${workspaceFolder}/api": "${workspaceFolder}/api"
			},
			"log": false,
			"xdebugSettings": {
				"max_data": 65535,
				"show_hidden": 1,
				"max_children": 128,
				"max_depth": 5
			},
			"skipFiles": [
				"${workspaceFolder}/vendor/**"
			],
			"presentation": {
				"group": "2-backend",
				"order": 2
			}
		},

		// ─────────────────────────────────────────────────────────────────────
		// TESTS — PHPUnit
		//
		// Runs the full PHPUnit test suite and stops on the first error.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🧪 Tests — PHPUnit",
			"type": "php",
			"request": "launch",
			"program": "${workspaceFolder}/vendor/bin/phpunit",
			"args": [
				"--configuration", "${workspaceFolder}/phpunit.xml",
				"--stop-on-failure"
			],
			"port": 9003,
			"env": {
				"XDEBUG_MODE": "debug",
				"XDEBUG_CONFIG": "client_host=127.0.0.1 client_port=9003 start_with_request=yes"
			},
			"pathMappings": {
				"${workspaceFolder}": "${workspaceFolder}"
			},
			"skipFiles": [
				"${workspaceFolder}/vendor/**"
			],
			"presentation": {
				"group": "3-tests",
				"order": 1
			}
		}
	],

	// ─────────────────────────────────────────────────────────────────────────
	// COMPOUND — Full stack (frontend + backend at the same time)
	//
	// Launches both the Chrome debugger and the PHP server+Xdebug listener.
	// Make sure `npm run dev` is already running before using this compound.
	// ─────────────────────────────────────────────────────────────────────────
	"compounds": [
		{
			"name": "🚀 Full Stack — Frontend + Backend",
			"configurations": [
				"🟠 Frontend — Chrome (SvelteKit / Vite)",
				"🐘 Backend — PHP (Xdebug)"
			],
			"presentation": {
				"group": "0-fullstack",
				"order": 1
			},
			"stopAll": true
		}
	]
}
