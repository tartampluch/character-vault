{
	"version": "0.2.0",
	// =========================================================================
	// CHARACTER VAULT — VS Code Launch Configurations
	//
	// PHP binary resolution (handled by scripts/php-dev.sh):
	//   For all PHP-related configurations, the wrapper script automatically
	//   picks the best available PHP:
	//     1. CHAR_VAULT_PHP env var (explicit override)
	//     2. System PHP with Xdebug loaded   (for debug sessions)
	//     3. .build-tools/bin/php            (portable, cached by build.sh)
	//     4. System PHP ≥ 8.1               (fallback)
	//
	// Environment variables (.env support):
	//   api/config.php automatically reads .env from the project root.
	//   Create .env from the template: cp .env.example .env
	//   Variables set in .env are used as FALLBACK — the process environment
	//   always takes priority. You can also define extra vars via the "env"
	//   key in any configuration below.
	//
	// Quick start:
	//   • 🚀 Full Stack  → starts Vite + PHP server + attaches both debuggers
	//   • 🎮 Run artifact → starts the built artifact (run.sh) + Chrome
	//   • Individual configs are organized in groups (1-frontend, 2-backend…)
	// =========================================================================
	"configurations": [

		// ─────────────────────────────────────────────────────────────────────
		// FRONTEND — SvelteKit dev server (Vite, port 5173)
		//
		// Requires: npm run dev to be running (or use the compound below).
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🟠 Frontend — Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				"/@fs/*": "${workspaceFolder}/*",
				"/*": "${webRoot}/*"
			},
			"smartStep": true,
			"skipFiles": [
				"<node_internals>/**",
				"**/node_modules/**",
				"**/.svelte-kit/**"
			],
			"presentation": { "group": "1-frontend", "order": 1 }
		},
		{
			"name": "🟠 Frontend — Edge",
			"type": "msedge",
			"request": "launch",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				"/@fs/*": "${workspaceFolder}/*",
				"/*": "${webRoot}/*"
			},
			"smartStep": true,
			"skipFiles": [
				"<node_internals>/**",
				"**/node_modules/**",
				"**/.svelte-kit/**"
			],
			"presentation": { "group": "1-frontend", "order": 2 }
		},

		// ─────────────────────────────────────────────────────────────────────
		// BACKEND — PHP debug listener (Xdebug, port 9003)
		//
		// Listens for an incoming Xdebug connection — use this when the PHP
		// server is started separately (e.g. by another terminal or task).
		//
		// Requires:
		//   • Xdebug installed in the PHP binary used by the server.
		//     scripts/php-dev.sh prefers system PHP when XDEBUG_MODE is set.
		//   • PHP server running with Xdebug enabled (see compound below or
		//     the "spawn" variant further down).
		//
		// Xdebug setup (once per system):
		//   macOS:  pecl install xdebug   (after: brew install php)
		//   Linux:  apt install php-xdebug
		//   Then add to php.ini / xdebug.ini:
		//     zend_extension=xdebug
		//     xdebug.mode=debug
		//     xdebug.start_with_request=yes
		//     xdebug.client_host=127.0.0.1
		//     xdebug.client_port=9003
		//   Or just use the env vars injected in the "spawn" config below.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🐘 Backend — PHP (listen for Xdebug)",
			"type": "php",
			"request": "launch",
			"port": 9003,
			"pathMappings": {
				"${workspaceFolder}/api": "${workspaceFolder}/api"
			},
			"log": false,
			"xdebugSettings": {
				"max_data": 65535,
				"show_hidden": 1,
				"max_children": 128,
				"max_depth": 5
			},
			"skipFiles": ["${workspaceFolder}/vendor/**"],
			"presentation": { "group": "2-backend", "order": 1 }
		},

		// ─────────────────────────────────────────────────────────────────────
		// BACKEND — PHP dev server + Xdebug (spawn)
		//
		// Spawns the PHP server via scripts/php-dev.sh and simultaneously
		// listens for Xdebug.  Xdebug env vars are injected at launch so no
		// permanent php.ini change is required — only the Xdebug extension
		// itself must be installed (pecl install xdebug / apt install php-xdebug).
		//
		// scripts/php-dev.sh will pick a system PHP that has Xdebug loaded.
		// If none is found, the server starts without Xdebug and a warning is
		// printed — useful for running without breakpoints.
		//
		// To use a specific PHP binary, set CHAR_VAULT_PHP in your shell or
		// add it to the "env" block below.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🐘 Backend — PHP (spawn server + Xdebug)",
			"type": "php",
			"request": "launch",
			"runtimeExecutable": "${workspaceFolder}/scripts/php-dev.sh",
			"runtimeArgs": [
				"-S", "localhost:8080",
				"-t", "${workspaceFolder}/api",
				"${workspaceFolder}/api/index.php"
			],
			"port": 9003,
			"env": {
				// Xdebug environment — injected so no permanent php.ini edit needed.
				// php-dev.sh uses XDEBUG_MODE to prefer a system PHP with Xdebug.
				"XDEBUG_MODE":   "debug",
				"XDEBUG_CONFIG": "client_host=127.0.0.1 client_port=9003 start_with_request=yes",
				// Application environment loaded by api/config.php.
				// .env in the project root is also read automatically.
				// Uncomment or add variables as needed:
				// "APP_ENV": "development",
				// "DB_PATH": "",
				// "CORS_ORIGIN": "http://localhost:5173"
			},
			"pathMappings": {
				"${workspaceFolder}/api": "${workspaceFolder}/api"
			},
			"log": false,
			"xdebugSettings": {
				"max_data": 65535,
				"show_hidden": 1,
				"max_children": 128,
				"max_depth": 5
			},
			"skipFiles": ["${workspaceFolder}/vendor/**"],
			"presentation": { "group": "2-backend", "order": 2 }
		},

		// ─────────────────────────────────────────────────────────────────────
		// TESTS — PHPUnit (with Xdebug for breakpoints in tests)
		//
		// Runs the full PHPUnit test suite through scripts/php-dev.sh.
		// Breakpoints in both test files and api/ source files are supported.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🧪 Tests — PHPUnit",
			"type": "php",
			"request": "launch",
			"runtimeExecutable": "${workspaceFolder}/scripts/php-dev.sh",
			"program": "${workspaceFolder}/vendor/bin/phpunit",
			"args": [
				"--configuration", "${workspaceFolder}/phpunit.xml",
				"--stop-on-failure"
			],
			"port": 9003,
			"env": {
				"XDEBUG_MODE":   "debug",
				"XDEBUG_CONFIG": "client_host=127.0.0.1 client_port=9003 start_with_request=yes"
			},
			"pathMappings": {
				"${workspaceFolder}": "${workspaceFolder}"
			},
			"skipFiles": ["${workspaceFolder}/vendor/**"],
			"presentation": { "group": "3-tests", "order": 1 }
		},

		// ─────────────────────────────────────────────────────────────────────
		// RUN ARTIFACT — Attach Chrome to the built artifact served by run.sh
		//
		// Use this after running scripts/build.sh to test the production build
		// locally.  The task "Run: Local server (run.sh)" is started
		// automatically as a pre-launch task.
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🎮 Run artifact — Chrome",
			"type": "chrome",
			"request": "launch",
			"url": "http://localhost:8080",
			"webRoot": "${workspaceFolder}/src",
			"sourceMapPathOverrides": {
				"/@fs/*": "${workspaceFolder}/*",
				"/*": "${webRoot}/*"
			},
			"smartStep": true,
			"skipFiles": [
				"<node_internals>/**",
				"**/node_modules/**"
			],
			"preLaunchTask": "Run: Local server (run.sh)",
			"presentation": { "group": "4-artifact", "order": 1 }
		}
	],

	// =========================================================================
	// COMPOUND CONFIGURATIONS — launch multiple debuggers at once
	// =========================================================================
	"compounds": [

		// ─────────────────────────────────────────────────────────────────────
		// 🚀 Full Stack — the main development compound
		//
		// What it does:
		//   1. Starts the Vite dev server (background task)
		//   2. Spawns the PHP server with Xdebug via php-dev.sh
		//   3. Attaches Chrome to http://localhost:5173
		//
		// Prerequisites:
		//   • npm install        (first time)
		//   • cp .env.example .env  (then edit as needed)
		//   • Xdebug installed in system PHP (optional — server starts without it)
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🚀 Full Stack — Vite + PHP + Chrome",
			"configurations": [
				"🐘 Backend — PHP (spawn server + Xdebug)",
				"🟠 Frontend — Chrome"
			],
			"preLaunchTask": "Start: Vite dev server",
			"presentation": { "group": "0-fullstack", "order": 1 },
			"stopAll": true
		},

		// ─────────────────────────────────────────────────────────────────────
		// 🚀 Full Stack (Edge variant)
		// ─────────────────────────────────────────────────────────────────────
		{
			"name": "🚀 Full Stack — Vite + PHP + Edge",
			"configurations": [
				"🐘 Backend — PHP (spawn server + Xdebug)",
				"🟠 Frontend — Edge"
			],
			"preLaunchTask": "Start: Vite dev server",
			"presentation": { "group": "0-fullstack", "order": 2 },
			"stopAll": true
		}
	]
}
