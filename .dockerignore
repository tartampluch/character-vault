# =============================================================================
# .dockerignore — Exclude files from the Docker build context
#
# Without this file, Docker sends the entire project tree to the daemon,
# including large directories (node_modules, vendor) and sensitive files
# (.env), which slows builds and leaks secrets into the build context.
#
# The Dockerfile only COPYs what it needs explicitly; this file prevents
# accidental inclusion and ensures the context is minimal.
# =============================================================================

# Dependencies (re-installed inside the image from lockfiles)
node_modules/
vendor/

# Build artifacts (generated by previous builds — not needed as input)
build/
.svelte-kit/
dist/
dist-pkg/

# Portable build tools (host-only; the Dockerfile uses its own package manager)
.build-tools/

# Sensitive configuration — never send to Docker daemon
.env
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# OS artefacts
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
*.swp
*.swo

# Git history (not needed for the build)
.git/
.gitignore

# BuildKit cache directories (host-side; not part of the source)
.buildx-cache/
.buildx-cache-new/
