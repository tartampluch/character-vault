node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Test coverage reports (generated by `npm test -- --coverage`, never commit)
# Run the "Test: Coverage report" VS Code task to regenerate locally.
/coverage/

# PHP / Composer
/vendor/
composer.lock

# SQLite database files (never commit — use migrations to recreate)
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# PHP rate limiting temp files (created in /tmp by api/middleware.php)
# These are OS-level temp files, so no gitignore needed.
# Documented here for clarity.

# PHPUnit result cache (generated by --cache-result / repeat-failed)
.phpunit.result.cache
.phpunit.cache/

# Build artefacts
# compressed tarballs
/dist-pkg/
# extracted deployment artifacts (used by run.sh)
/dist/
# BuildKit local cache directories (may be created in the project root by some
# CI environments or manual docker buildx invocations).
# Note: the system /tmp/.buildx-cache* paths are outside the repository and
# never need a gitignore entry — these patterns target any cache accidentally
# created inside the project tree.
/.buildx-cache/
/.buildx-cache-new/

# Portable build tools (downloaded by scripts/build.sh — never commit)
/.build-tools/

# Global rule source files in storage/rules/ are written at runtime by GMs
# via PUT /api/global-rules/{filename} and must NOT be committed.
# The directory itself is tracked via storage/rules/.gitkeep.
/storage/rules/*.json
