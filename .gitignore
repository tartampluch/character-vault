node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# PHP / Composer
/vendor/
composer.lock

# SQLite database files (never commit — use migrations to recreate)
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# PHP rate limiting temp files (created in /tmp by api/middleware.php)
# These are OS-level temp files, so no gitignore needed.
# Documented here for clarity.

# PHPUnit result cache (generated by --cache-result / repeat-failed)
.phpunit.result.cache
.phpunit.cache/

# Build artefacts
/dist-pkg/           # compressed tarballs
/dist/               # extracted deployment artifacts (used by run.sh)
/tmp/.buildx-cache/
/tmp/.buildx-cache-new/

# Portable build tools (downloaded by scripts/build.sh — never commit)
/.build-tools/
