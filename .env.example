# =============================================================================
# Character Vault — Environment configuration
# =============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the values that apply to your setup (see comments below).
# 3. Never commit .env — it is listed in .gitignore.
#
# PRIORITY
# --------
# Variables are resolved in this order (highest wins):
#   1. Server / process environment  (set by Apache, Docker, or your shell)
#   2. This .env file
#   3. Built-in defaults (safe for zero-config local development)
#
# ON SHARED HOSTING (OVH, etc.)
# ------------------------------
# Place .env in the same directory as the extracted tarball (next to api/).
# It is the only reliable way to configure the application when you cannot
# set server-level environment variables through the control panel.
#
# FOR LOCAL DEVELOPMENT
# ---------------------
# The defaults below work out of the box — you only need APP_ENV=development
# (which is already the default). Edit only what you need to change.
# =============================================================================


# =============================================================================
# APP_ENV — Application environment
# =============================================================================
# Values:  development | production
# Default: development
#
# - development : verbose errors, SQLite in project root, permissive settings.
# - production  : errors hidden, strict security, SQLite in DB_PATH below.
#
# ⚠ Always set APP_ENV=production on shared hosting / public servers.
# =============================================================================
APP_ENV=development


# =============================================================================
# DB_PATH — Path to the SQLite database file
# =============================================================================
# Default (development): <project-root>/database.sqlite
# Default (production) : /var/lib/character-vault/database.sqlite
#
# IMPORTANT: On shared hosting, choose a path that is:
#   • OUTSIDE the web-accessible directory (not inside public_html, www, etc.)
#   • Writable by the PHP process
#
# Examples:
#   Shared hosting (OVH):  DB_PATH=/home/yourlogin/private/cvault.sqlite
#   VPS / dedicated:       DB_PATH=/var/lib/character-vault/database.sqlite
#   Local development:     DB_PATH=   (leave blank to use the default)
# =============================================================================
# DB_PATH=


# =============================================================================
# CORS_ORIGIN — Extra allowed CORS origin for the API
# =============================================================================
# Default: only localhost URLs are allowed (safe for local development).
#
# In production, set this to your public domain so the browser can call the
# PHP API from your website:
#   CORS_ORIGIN=https://yourvtt.example.com
#
# Leave blank in development (localhost origins are always permitted).
# =============================================================================
# CORS_ORIGIN=


# =============================================================================
# APP_TESTING — PHPUnit in-memory database flag  [INTERNAL — do not set manually]
# =============================================================================
# When set to "1", api/config.php switches the database to sqlite::memory: so
# PHPUnit tests never touch the filesystem.
# This variable is set automatically by phpunit.xml via <php><env> directives.
# Never set it in a real .env file — doing so would break the production database.
# =============================================================================
# APP_TESTING=1
